---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gracias | Plan Estrategico 2026" description="Confirmacion de registro enviada correctamente.">
  <main class="thank-you-shell">
    <section class="section">
      <div class="thank-you-card surface-card surface-card-emphasis fade-rise">
        <p class="eyebrow">Registro enviado</p>
        <h1>Gracias por completar el formulario</h1>
        <p class="hero-description">
          Si el Google Apps Script ya esta configurado, la informacion quedo registrada en tu Google Sheet.
          En unos segundos te llevaremos de regreso al inicio. Si necesitas enviar otro contacto, tambien puedes usar los botones de abajo.
        </p>
        <div class="hero-actions thank-you-actions">
          <a class="button button-primary" href="/">Volver al inicio</a>
          <a class="button button-ghost" href="/#registro">Enviar otro registro</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  if (typeof window !== "undefined") {
    window.setTimeout(() => {
      window.location.replace("/");
    }, 3500);
  }
</script>
