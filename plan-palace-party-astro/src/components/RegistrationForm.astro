---
const { kickoffDate = "Miércoles 15 de abril, 10:00 AM (hora de Honduras)", googleScriptUrl = "" } = Astro.props;
const isConfigured = Boolean(googleScriptUrl);
---

<div class="registration-layout">
  <div class="registration-copy">
    <article class="surface-card surface-card-emphasis">
      <p class="mini-label">Registro del punto focal</p>
      <h3>Lo único que necesitamos para confirmar participación</h3>
      <ul class="detail-list detail-list-compact">
        <li>Nombre de la organización.</li>
        <li>Tamaño de la organización.</li>
        <li>Datos del punto focal principal.</li>
        <li>Datos de una persona de respaldo.</li>
        <li>Confirmacion de la reunión de arranque del miércoles 15 de abril a las 10:00 AM (hora de Honduras).</li>
        <li>Comentarios relevantes o participantes adicionales, si aplica.</li>
      </ul>      
    </article>

    <article class="surface-card">
      <p class="mini-label">Antes de enviar</p>
      <h3>Un formulario corto y muy fácil de completar</h3>
      <p class="section-copy section-copy-tight">
        Este formulario tarda menos de 3 minutos. Recuerda que la reunión de arranque ya está confirmada para el miércoles 15 de abril, a las 10:00 AM (hora de Honduras).
      </p>
      <p class="small-note">Consejo: ten a mano el correo del punto focal y de la persona de respaldo antes de empezar.</p>
    </article>
  </div>

  <div class="surface-card form-card">
    {!isConfigured && (
      <div class="config-alert" role="status">
        <strong>Falta configurar el enlace de Google Apps Script.</strong>
        <span>Agrega <code>PUBLIC_GOOGLE_SCRIPT_URL</code> en tu entorno para activar el envio real a Google Sheets.</span>
      </div>
    )}

    <form
      id="registration-form"
      class="registration-form"
      method="POST"
      action={isConfigured ? googleScriptUrl : "#"}
      accept-charset="UTF-8"
      data-configured={isConfigured ? "true" : "false"}
    >
      <input type="hidden" name="redirectUrl" value="" />
      <input type="hidden" name="source" value="plan-palace-party-astro" />
      <input type="hidden" name="kickoffDate" value={kickoffDate} />

      <div class="honeypot" aria-hidden="true">
        <label for="website">No llenar este campo</label>
        <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <div class="form-grid">
        <label class="field field-full">
          <span>Nombre de la organizacion</span>
          <input name="orgName" autocomplete="organization" required />
        </label>

        <label class="field field-full">
          <span>Tamaño de la Organización</span>
          <select name="orgSize" required>
            <option value="" selected disabled>Selecciona una opción</option>
            <option value="1-10">1-10</option>
            <option value="11-20">11-20</option>
            <option value="Más de 20">Más de 20</option>
          </select>
          <small class="field-help">Número de personas que trabajan para la organización bajo un contrato.</small>
        </label>

        <label class="field">
          <span>Nombre del punto focal</span>
          <input name="focalName" autocomplete="name" required />
        </label>

        <label class="field">
          <span>Correo del punto focal</span>
          <input name="focalEmail" type="email" autocomplete="email" required />
        </label>

        <label class="field field-full">
          <span>Telefono del punto focal</span>
          <input name="focalPhone" type="tel" autocomplete="tel" />
        </label>

        <label class="field">
          <span>Nombre de la persona de respaldo</span>
          <input name="backupName" autocomplete="name" required />
        </label>

        <label class="field">
          <span>Correo de la persona de respaldo</span>
          <input name="backupEmail" type="email" autocomplete="email" required />
        </label>

        <label class="field field-full">
          <span>Reunión de arranque confirmada</span>
          <input value={kickoffDate} readonly />
        </label>
      </div>

      <label class="field field-full">
        <span>Participantes adicionales</span>
        <textarea
          name="additionalParticipants"
          rows="4"
          placeholder="Nombres, roles o personas que tambien participarian en algunas sesiones."
        ></textarea>
      </label>

      <label class="field field-full">
        <span>Comentarios o preguntas</span>
        <textarea
          name="comments"
          rows="4"
          placeholder="Cualquier detalle que debamos conocer antes de iniciar."
        ></textarea>
      </label>

      <button class="button button-primary button-full" type="submit" disabled={!isConfigured}>
        {isConfigured ? "Enviar registro" : "Configura el Google Script para activar el formulario"}
      </button>

      <p class="form-footnote">Si tienes problemas para enviar el formulario, por favor envia un correo a con la información solicitada a narvaezmena@gmail.com</p>
    </form>
  </div>
</div>

<script is:inline>
  const form = document.getElementById("registration-form");

  if (form) {
    const redirectInput = form.querySelector('input[name="redirectUrl"]');
    const statusNote = form.querySelector(".form-footnote");
    const defaultStatusText = statusNote?.textContent || "";
    const nextUrl = `${window.location.origin}/gracias`;

    if (redirectInput && window.location) {
      redirectInput.value = nextUrl;
    }

    const resetSubmitState = (message) => {
      const submitButton = form.querySelector('button[type="submit"]');

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        delete submitButton.dataset.loading;
        submitButton.textContent = "Enviar registro";
      }

      if (statusNote) {
        statusNote.textContent = message || defaultStatusText;
      }
    };

    form.addEventListener("submit", async (event) => {
      if (form.dataset.configured !== "true") {
        event.preventDefault();
        return;
      }

      const submitButton = form.querySelector('button[type="submit"]');

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.dataset.loading = "true";
        submitButton.textContent = "Enviando registro...";
      }

      if (statusNote) {
        statusNote.textContent = defaultStatusText;
      }

      event.preventDefault();

      const targetUrl = form.getAttribute("action") || "";
      const formData = new FormData(form);
      const payload = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        if (typeof value === "string") {
          payload.append(key, value);
        }
      }

      try {
        await fetch(targetUrl, {
          method: "POST",
          mode: "no-cors",
          body: payload,
        });

        window.location.assign(nextUrl);
      } catch (error) {
        resetSubmitState("No pudimos enviar el formulario. Intenta de nuevo en unos segundos.");
      }
    });
  }
</script>
