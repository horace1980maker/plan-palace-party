---
const { items = [] } = Astro.props;
let stepIndex = 0;
---

<div class="timeline">
  {items.map((item) => {
    const isSpecial = item.type === "special";
    const badge = isSpecial ? item.badge || "IA" : String(++stepIndex).padStart(2, "0");

    return (
      <article class={`timeline-item ${isSpecial ? "timeline-item-special" : ""}`}>
        <div class={`timeline-index ${isSpecial ? "timeline-index-special" : ""}`}>{badge}</div>
        <div class={`surface-card timeline-card ${isSpecial ? "surface-card-emphasis timeline-card-special" : ""}`}>
          <p class={`timeline-date ${isSpecial ? "timeline-date-special" : ""}`}>{item.date}</p>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          {item.note && <p class={`timeline-note ${isSpecial ? "timeline-note-special" : ""}`}>{item.note}</p>}
        </div>
      </article>
    );
  })}
</div>
